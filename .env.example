DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000

# SQLite by default. For Postgres, set DATABASE_URL.
# DATABASE_URL=postgres://user:password@host:5432/dbname
DB_PATH=data/db.sqlite3

# Main fallback Stripe pair.
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Optional currency-specific keypairs for the bonus requirement.
STRIPE_SECRET_KEY_USD=sk_test_xxx
STRIPE_PUBLISHABLE_KEY_USD=pk_test_xxx
STRIPE_SECRET_KEY_EUR=sk_test_xxx
STRIPE_PUBLISHABLE_KEY_EUR=pk_test_xxx

DJANGO_CREATE_SUPERUSER=1
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=admin12345
DJANGO_LOAD_DEMO_DATA=1
